# UroFlow Environment Configuration Template

# This file represents the sensitive configurations found in src/config.h.
# Avoid committing the real file to Git if it contains private credentials.

# ─── WiFi Credentials ──────────────────────────────────────────────────
WIFI_SSID="YourWiFiSSID"
WIFI_PASS="YourWiFiPassword"

# ─── Cloud Endpoint ─────────────────────────────────────────────────────
# Deployment URL for your Google Apps Script
CLOUD_UPLOAD_URL="https://script.google.com/macros/s/AKfy.../exec"

# ─── Acaia Device MAC (Optional) ──────────────────────────────────────
# The device will scan and find the scale automatically if this is not set.
# Once connected, the MAC will be saved to NVS.
# STORED_MAC="XX:XX:XX:XX:XX:XX"
